# Local-only Ollama endpoint. By default the application allows localhost and private network addresses.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional preferred local model. Leave empty to use the first installed Ollama model.
OLLAMA_MODEL=qwen2.5:7b

# Timeout for one local LLM generation request.
OLLAMA_GENERATION_TIMEOUT_SECONDS=180

# Keep false for a closed local contour. Set true only when a remote public Ollama endpoint is intentionally used.
OLLAMA_ALLOW_PUBLIC_ENDPOINT=false

# Application JWT signing key. Replace for a real deployment.
APP_SECRET_KEY=change-me-in-production
