# Path to the optional trained narrow-domain FOS generator artifact.
# The application can still work without this file by using template and expert-example fallback modes.
NARROW_LLM_MODEL_PATH=storage/models/narrow_fos_model.json

# Generation controls for the narrow-domain model.
NARROW_LLM_MODEL_VERSION=narrow-fos-generator-v0.1
NARROW_LLM_MAX_ITEMS=40
NARROW_LLM_FALLBACK_TO_TEMPLATE=true

# Application JWT signing key. Replace for a real deployment.
APP_SECRET_KEY=change-me-in-production
